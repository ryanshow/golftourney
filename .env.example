# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.up.railway.app,your-custom-domain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.up.railway.app,https://your-custom-domain.com

# Database — Railway sets this automatically when a PostgreSQL service is linked
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Media file uploads
# Set to your Railway volume mount path, e.g. /data/media
MEDIA_ROOT=/data/media

# Email — used for raffle donation notifications and other admin alerts
# Remove EMAIL_HOST (or leave blank) to print emails to the console instead of sending them.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@claygolftournament.org
# Recipient for admin notifications; falls back to TournamentInfo contact email if blank.
ADMIN_EMAIL=admin@claygolftournament.org

# Square Payment Settings
# Get these from your Square Developer Dashboard: https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_APPLICATION_ID=your-square-application-id
SQUARE_ENVIRONMENT=production
